<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %> — EduTrack</title>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="app-shell">
  <%- include('../partials/sidebar') %>
  <main class="main">
    <div class="topbar">
      <span class="topbar-title"><%= student ? 'Edit Student' : 'Add Student' %></span>
      <div class="topbar-actions">
        <a href="/students" class="btn btn-outline btn-sm">← Back</a>
      </div>
    </div>

    <div class="page-body" style="max-width:820px">
      <% if (error) { %>
        <div class="alert alert-error">✕ <%= error %></div>
      <% } %>

      <%
        const v      = student || {};
        const action = student ? `/students/${student._id}?_method=PUT` : '/students';
      %>
      <form method="POST" action="<%= action %>">

        <!-- Section: Identity -->
        <div class="card" style="margin-bottom:20px">
          <div class="card-head"><span class="card-title">Identity</span></div>
          <div class="card-body">
            <div class="form-grid-2">
              <div class="form-group">
                <label class="form-label">Student ID <sup>*</sup></label>
                <input class="form-control" type="text" name="studentId"
                       value="<%= v.studentId||'' %>" required placeholder="STU-2024-001"
                       style="font-family:var(--font-mono)"/>
              </div>
              <div class="form-group">
                <label class="form-label">Email <sup>*</sup></label>
                <input class="form-control" type="email" name="email"
                       value="<%= v.email||'' %>" required placeholder="student@university.edu"/>
              </div>
              <div class="form-group">
                <label class="form-label">First Name <sup>*</sup></label>
                <input class="form-control" type="text" name="firstName"
                       value="<%= v.firstName||'' %>" required/>
              </div>
              <div class="form-group">
                <label class="form-label">Last Name <sup>*</sup></label>
                <input class="form-control" type="text" name="lastName"
                       value="<%= v.lastName||'' %>" required/>
              </div>
              <div class="form-group">
                <label class="form-label">Phone</label>
                <input class="form-control" type="text" name="phone"
                       value="<%= v.phone||'' %>" placeholder="+92 300 0000000"/>
              </div>
              <div class="form-group">
                <label class="form-label">Date of Birth</label>
                <input class="form-control" type="date" name="dob"
                       value="<%= v.dob ? new Date(v.dob).toISOString().split('T')[0] : '' %>"/>
              </div>
              <div class="form-group">
                <label class="form-label">Gender</label>
                <select class="form-control" name="gender">
                  <% [['prefer_not','Prefer not to say'],['male','Male'],['female','Female'],['other','Other']].forEach(([val,lbl]) => { %>
                    <option value="<%= val %>" <%= v.gender===val?'selected':'' %>><%= lbl %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Guardian / Parent</label>
                <input class="form-control" type="text" name="guardian"
                       value="<%= v.guardian||'' %>" placeholder="Guardian name"/>
              </div>
              <div class="form-group col-span-2">
                <label class="form-label">Address</label>
                <input class="form-control" type="text" name="address"
                       value="<%= v.address||'' %>" placeholder="Current residential address"/>
              </div>
            </div>
          </div>
        </div>

        <!-- Section: Academic -->
        <div class="card" style="margin-bottom:20px">
          <div class="card-head"><span class="card-title">Academic Details</span></div>
          <div class="card-body">
            <div class="form-grid-3">
              <div class="form-group">
                <label class="form-label">Department <sup>*</sup></label>
                <select class="form-control" name="department" required>
                  <option value="">Select…</option>
                  <% DEPARTMENTS.forEach(d => { %>
                    <option value="<%= d %>" <%= v.department===d?'selected':'' %>><%= d %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Semester <sup>*</sup></label>
                <select class="form-control" name="semester" required>
                  <% for(let i=1;i<=8;i++) { %>
                    <option value="<%= i %>" <%= v.semester==i?'selected':'' %>>Semester <%= i %></option>
                  <% } %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">Status</label>
                <select class="form-control" name="status">
                  <% ['active','inactive','graduated','suspended'].forEach(s => { %>
                    <option value="<%= s %>" <%= v.status===s?'selected':'' %>><%= s.charAt(0).toUpperCase()+s.slice(1) %></option>
                  <% }) %>
                </select>
              </div>
              <div class="form-group">
                <label class="form-label">CGPA <span class="text-dim" style="font-size:11px">(0.0–4.0)</span></label>
                <input class="form-control" type="number" name="cgpa"
                       min="0" max="4" step="0.01" style="font-family:var(--font-mono)"
                       value="<%= v.cgpa!=null ? v.cgpa : '' %>" placeholder="3.50"/>
              </div>
              <div class="form-group col-span-2">
                <label class="form-label">Notes <span class="text-dim" style="font-size:11px">(max 600 chars)</span></label>
                <textarea class="form-control" name="notes" maxlength="600"
                          placeholder="Any additional notes…"><%= v.notes||'' %></textarea>
              </div>
            </div>
          </div>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn btn-primary">
            <%= student ? '✓ Save Changes' : '＋ Enroll Student' %>
          </button>
          <a href="/students" class="btn btn-outline">Cancel</a>
        </div>
      </form>
    </div>
  </main>
</div>
<script src="/js/app.js"></script>
</body>
</html>
