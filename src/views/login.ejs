<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Sign In — EduTrack</title>
  <%- include('partials/head-meta') %>
  <link rel="stylesheet" href="/css/style.css"/>
</head>
<body>
<div class="auth-page">

  <div class="auth-left">
    <div class="auth-left-brand">
      <%- include('partials/logo', { size: 'lg' }) %>
    </div>
    <div class="auth-left-quote">
      <blockquote>"Education is not the filling of a pail, but the lighting of a fire."</blockquote>
      <cite>— W.B. Yeats</cite>
    </div>
    <div class="auth-features">
      <div class="auth-feature">◈ Real-time dashboard analytics</div>
      <div class="auth-feature">◉ 60+ student records with audit trail</div>
      <div class="auth-feature">↓ CSV export & role-based access</div>
    </div>
  </div>

  <!-- Right panel — form -->
  <div class="auth-right">
    <div class="auth-form-wrap">
      <h1>Welcome back</h1>
      <p>Sign in to your EduTrack account</p>

      <% if (error) { %>
        <div class="alert alert-error">✕ <%= error %></div>
      <% } %>

      <form method="POST" action="/login">
        <div class="form-group" style="margin-bottom:16px">
          <label class="form-label">Username</label>
          <input class="form-control" type="text" name="username"
                 value="<%= prefill || '' %>" required autocomplete="username"
                 placeholder="your username"/>
        </div>
        <div class="form-group" style="margin-bottom:24px">
          <label class="form-label">Password</label>
          <input class="form-control" type="password" name="password"
                 required autocomplete="current-password" placeholder="••••••••"/>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Sign In</button>
      </form>

      <p class="auth-footer-link">No account? <a href="/register">Create one</a></p>
      <p class="auth-footer-link" style="margin-top:8px;font-size:12px;color:var(--ink-4)">
        Demo: <code>admin</code> / <code>admin123</code> ·
        <code>staff1</code> / <code>staff123</code> ·
        <code>viewer1</code> / <code>viewer123</code>
      </p>
    </div>
  </div>
</div>
<script src="/js/app.js"></script>
</body>
</html>
